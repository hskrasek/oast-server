{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "oastsh/server",
    "type": "project",
    "description": "The Laravel core of oast.sh — a spec-first platform for reviewing and iterating on API specifications with a multi-model design panel (the Council).",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "AGPL-3.0-only",
    "require": {
        "php": "^8.5",
        "aws/aws-sdk-php": "^3.387.2",
        "crell/api-problem": "^3.8",
        "laravel/ai": "^0.8.1",
        "laravel/fortify": "^1.37.2",
        "laravel/framework": "^13.16.1",
        "laravel/sanctum": "^4.3.2",
        "laravel/tinker": "^3.0.2",
        "nunomaduro/essentials": "^1.2",
        "symfony/yaml": "^8.1.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.10",
        "laravel/pail": "^1.2.7",
        "laravel/pao": "^1.1.1",
        "laravel/pint": "^1.29.3",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.7.3",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "phpstan/phpstan": "^2.2.2",
        "rector/rector": "^2.4.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "bun install",
            "bun run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"bun run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan clear",
            "@update:requirements"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "update:requirements": [
            "composer bump",
            "bunx npm-check-updates -u"
        ],
        "lint": [
            "rector",
            "pint --parallel",
            "bun run lint"
        ],
        "test:type-coverage": "@php -d memory_limit=1G vendor/bin/pest --type-coverage --min=100 --exclude-group=live",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run",
            "bun run test:lint"
        ],
        "test:unit": "XDEBUG_MODE=\"coverage\" pest --parallel --coverage --exactly=100.0 --exclude-group=live",
        "test:types": "phpstan --memory-limit=1G",
        "test": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
